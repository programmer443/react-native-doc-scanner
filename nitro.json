{
  "$schema": "https://nitro.margelo.com/nitro.schema.json",
  "cxxNamespace": ["docscanner"],
  "ios": {
    "iosModuleName": "DocScanner"
  },
  "android": {
    "androidNamespace": ["docscanner"],
    "androidCxxLibName": "DocScanner"
  },
  "autolinking": {
    "DocScanner": {
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridDocScanner"
      },
      "android": {
        "language": "kotlin",
        "implementationClassName": "HybridDocScanner"
      }
    }
  },
  "ignorePaths": ["**/node_modules"]
}
